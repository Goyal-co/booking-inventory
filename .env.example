# Copy to .env and fill in production values. Never commit .env.

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/booking_inventory?schema=public"

# --- Auth (generate with: openssl rand -base64 32) ---
# Use a UNIQUE secret per app in production (admin vs sales).
NEXTAUTH_SECRET="change-me-in-production-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Public URLs (used for CORS and links)
SALES_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
CUSTOMER_URL="http://localhost:3003"
RECEPTION_URL="http://localhost:3004"

# --- Email (Brevo) — same as EOI platform ---
# Put the real key only in local .env / .env.local (never commit it)
BREVO_API_KEY=""
EMAIL_FROM="noreply@your-domain.com"
EMAIL_FROM_NAME="Goyal & Co. | Hariyana Group"
# Optional absolute logo URL for email header
# EMAIL_LOGO_URL=https://booking.your-domain.com/logo.svg

# --- Integrations ---
TITAN_CRM_PROVIDER="mock"
TITAN_CRM_API_URL=""
TITAN_CRM_API_KEY=""
POST_CRM_PROVIDER="mock"
INTEGRATION_WEBHOOK_SECRET="change-me-integration-webhook-secret"
INTEGRATION_HUB_URL="http://localhost:3001"
BOOKING_INVENTORY_URL="http://localhost:3001"

# --- Object storage (same priority as EOI: Blob → S3 → local) ---
# Prefer BLOB_READ_WRITE_TOKEN on Vercel; otherwise S3/MinIO keys; else local disk for dev.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_w2cjlHtLld75PCey_rlHbo9DsW00YbciEywqlx6SNmG5w6d"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./storage"
STORAGE_PUBLIC_URL="/api/files"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# (also accepted: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
# S3_BUCKET="goyal-booking-documents"
# S3_REGION="ap-south-1"
# S3_ENDPOINT=""
# S3_FORCE_PATH_STYLE="true"
# S3_PUBLIC_URL=""

# --- Event bus (Phase D) ---
EVENT_BUS_PROVIDER=""

# --- Realtime WebSocket ---
WS_EMIT_URL="http://localhost:3002"
NEXT_PUBLIC_WS_URL="http://localhost:3002"
WS_PORT=3002
WS_INTERNAL_SECRET="change-me-ws-internal-secret-min-32-chars"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:3004"

# --- Redis (optional, for future scaling) ---
REDIS_URL="redis://localhost:6379"

# --- Local dev only: demo seed (NEVER set true in production) ---
# SEED_DEMO=true

# --- Production first deploy: Super Admin bootstrap ---
# Run once after db:push: pnpm db:bootstrap
# ORGANIZATION_NAME="Acme Realty"
# ORGANIZATION_SLUG="acme-realty"
# SUPER_ADMIN_EMAIL="admin@yourcompany.com"
# SUPER_ADMIN_NAME="Super Admin"
# SUPER_ADMIN_PASSWORD="use-a-strong-password-min-12-chars"

# --- Runtime ---
NODE_ENV=development
