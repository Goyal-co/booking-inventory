# Production environment — copy to .env.production / deploy secrets and fill in values.

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/booking_inventory?schema=public&sslmode=require

# --- Auth ---
NEXTAUTH_SECRET=generate-a-secure-random-string-at-least-32-chars
NEXTAUTH_URL=https://sales.your-domain.com

# Public URLs
SALES_URL=https://sales.your-domain.com
ADMIN_URL=https://admin.your-domain.com
CUSTOMER_URL=https://booking.your-domain.com
RECEPTION_URL=https://reception.your-domain.com

# --- Email (Brevo) — same pattern as EOI platform ---
# Put the real key only in deploy secrets / .env.production (never commit it)
BREVO_API_KEY=
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Goyal & Co. | Hariyana Group
# Optional: absolute URL to logo used in emails
# EMAIL_LOGO_URL=https://booking.your-domain.com/logo.svg

# --- Realtime ---
WS_EMIT_URL=https://ws.your-domain.com
NEXT_PUBLIC_WS_URL=https://ws.your-domain.com
WS_PORT=3002
WS_INTERNAL_SECRET=generate-a-secure-random-string-min-32-chars
CORS_ORIGINS=https://sales.your-domain.com,https://admin.your-domain.com,https://booking.your-domain.com,https://reception.your-domain.com

# --- Integrations ---
TITAN_CRM_PROVIDER=mock
POST_CRM_PROVIDER=mock
INTEGRATION_WEBHOOK_SECRET=change-me-integration-webhook-secret
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_w2cjlHtLld75PCey_rlHbo9DsW00YbciEywqlx6SNmG5w6d"
# --- Storage ---
STORAGE_PROVIDER=local

NODE_ENV=production
