{
  "name": "booking-inventory",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:sales": "turbo dev --filter=sales",
    "dev:admin": "turbo dev --filter=admin",
    "kill:dev": "node scripts/kill-port.js --wait",
    "dev:admin:clean": "node scripts/kill-port.js --wait && node -e \"require('fs').rmSync('apps/admin/.next',{recursive:true,force:true})\" && pnpm --filter @booking/database db:generate && turbo dev --filter=admin",
    "dev:sales:clean": "node scripts/kill-port.js --wait && node -e \"require('fs').rmSync('apps/sales/.next',{recursive:true,force:true})\" && pnpm --filter @booking/database db:generate && turbo dev --filter=sales",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @booking/database db:generate",
    "db:push": "pnpm --filter @booking/database db:push",
    "db:push:schema": "pnpm --filter @booking/database db:push:schema",
    "db:seed": "pnpm --filter @booking/database db:seed",
    "db:bootstrap": "pnpm --filter @booking/database db:bootstrap",
    "db:reset": "pnpm --filter @booking/database db:reset",
    "dev:ws": "turbo dev --filter=ws-server",
    "dev:ws:clean": "node scripts/kill-port.js 3002 --wait && turbo dev --filter=ws-server",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
