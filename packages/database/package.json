{
  "name": "@booking/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push:schema": "prisma db push --skip-generate",
    "db:seed": "pnpm exec tsx prisma/seed.ts",
    "db:bootstrap": "pnpm exec tsx prisma/bootstrap.ts",
    "db:reset": "prisma db push --force-reset && pnpm exec tsx prisma/seed.ts",
    "build": "prisma generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@booking/email": "workspace:*",
    "@booking/integrations": "workspace:*",
    "@booking/pdf": "workspace:*",
    "@booking/validators": "workspace:*",
    "@goyal/ecosystem-contracts": "workspace:*",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@booking/config-typescript": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
